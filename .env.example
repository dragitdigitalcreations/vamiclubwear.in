# ─────────────────────────────────────────────
# Vami Clubwear — Environment Variables Template
# Copy to .env.local and fill in real values.
# NEVER commit .env.local or .env to git.
# ─────────────────────────────────────────────

# ── Database ─────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/vami_clubwear?schema=public"

# ── Backend Server ───────────────────────────
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ── POS Integration ──────────────────────────
# Zoho Inventory webhook signing secret
ZOHO_WEBHOOK_SECRET=your-zoho-webhook-secret-here

# Tally Prime webhook signing secret
TALLY_WEBHOOK_SECRET=your-tally-webhook-secret-here

# ── WhatsApp Business API ─────────────────────
WHATSAPP_ACCESS_TOKEN=your-whatsapp-access-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_VERIFY_TOKEN=your-verify-token
WHATSAPP_BUSINESS_ACCOUNT_ID=your-waba-id

# ── Frontend (public vars — safe to expose) ──
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_ADMIN_API_KEY=your-admin-api-key-here

# ── Backend RBAC ────────────────────────────
ADMIN_API_KEY=your-admin-api-key-here
MANAGER_API_KEY=your-manager-api-key-here

# ── Cloudinary (media uploads) ───────────────
# Sign up free at https://cloudinary.com — copy from Dashboard > API Keys
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
