// Vami Clubwear — Production Database Schema
// Modular, location-aware inventory with optimistic locking.
// No external POS coupling at this stage.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL") // Neon: use pooled URL for runtime, direct for migrations
}

// ─────────────────────────────────────────────
// LOCATIONS
// Physical or logical stock locations (store, warehouse, etc.)
// ─────────────────────────────────────────────

model Location {
  id        String      @id @default(cuid())
  name      String      @unique  // "Main Store", "Warehouse"
  address   String?
  isActive  Boolean     @default(true)
  inventory Inventory[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

// ─────────────────────────────────────────────
// CATEGORIES
// Self-referential tree (e.g. "Fusion Wear > Anarkali Sets")
// ─────────────────────────────────────────────

model Category {
  id          String     @id @default(cuid())
  name        String     @unique
  slug        String     @unique
  description String?
  parentId    String?
  parent      Category?  @relation("SubCategory", fields: [parentId], references: [id])
  children    Category[] @relation("SubCategory")
  products    Product[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([slug])
}

// ─────────────────────────────────────────────
// PRODUCTS
// Presentation record — purchasable units live in ProductVariant
// ─────────────────────────────────────────────

enum MediaType {
  IMAGE
  VIDEO
}

// Product media — images and MP4 videos
model ProductMedia {
  id        String    @id @default(cuid())
  productId String
  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  type      MediaType @default(IMAGE)
  altText   String?
  isPrimary Boolean   @default(false)
  sortOrder Int       @default(0)
  createdAt DateTime  @default(now())

  @@index([productId])
}

model Product {
  id              String                @id @default(cuid())
  name            String
  slug            String                @unique
  // SINGLE-mode barcode — one for the whole product, shared by all variants.
  // Mutually exclusive with `colorBarcodes`: when perColorBarcode = true this stays null
  // and each colour bundle gets its own row in ProductColorBarcode.
  barcode         String?               @unique
  perColorBarcode Boolean               @default(false)
  description     String?               @db.Text
  basePrice       Decimal               @db.Decimal(10, 2)
  categoryId      String
  category        Category              @relation(fields: [categoryId], references: [id])
  variants        ProductVariant[]
  colorBarcodes   ProductColorBarcode[]
  media           ProductMedia[]
  isActive        Boolean               @default(true)
  isFeatured      Boolean               @default(false)
  deletedAt       DateTime?             // soft delete — preserves order history while hiding from storefront/admin listings
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  @@index([categoryId])
  @@index([slug])
  @@index([deletedAt])
  // Storefront listing hot path: WHERE deletedAt IS NULL AND isActive = true ORDER BY createdAt DESC
  @@index([deletedAt, isActive, createdAt(sort: Desc)])
}

// Per-colour barcode for products that carry one barcode per colour bundle
// (all sizes of a colour share the same barcode). Lookup falls through to this
// table when Product.barcode misses, then variants are filtered by `color`.
model ProductColorBarcode {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  color     String
  barcode   String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([productId, color])
  @@index([productId])
  @@index([barcode])
}

// ─────────────────────────────────────────────
// PRODUCT VARIANTS — Multi-dimensional SKU
// Each row = one unique purchasable configuration.
//
// Four fashion dimensions:
//   size      — XS | S | M | L | XL | XXL | Free Size | Custom
//   color     — "Emerald Green" + optional colorHex for UI swatches
//   fabric    — Pure Silk | Georgette | Chiffon | Velvet | ...
//   style     — Anarkali | Straight Cut | A-Line | Lehenga | Palazzo Set | ...
// ─────────────────────────────────────────────

model ProductVariant {
  id         String      @id @default(cuid())
  productId  String
  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)

  sku        String      @unique // e.g. VCW-ZFUS-GRN-M-SILK-ANKA

  size       String?
  color      String?
  colorHex   String?     // hex for UI swatches, e.g. "#50C878"
  fabric     String?
  style      String?     // garment silhouette / cut style

  price      Decimal     @db.Decimal(10, 2) // final selling price (not a modifier)

  inventory        Inventory[]
  orderItems       OrderItem[]
  inventoryHistory InventoryHistory[]

  isActive   Boolean     @default(true)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@index([productId])
  @@index([sku])
  @@index([fabric])
  @@index([style])
}

// ─────────────────────────────────────────────
// INVENTORY
// Tracked per variant per location.
// Optimistic locking via `version` prevents overselling.
// ─────────────────────────────────────────────

enum SyncStatus {
  SYNCED    // matches POS
  PENDING   // local change not yet pushed to POS
  CONFLICT  // mismatch detected; needs manual resolution
}

model Inventory {
  id         String         @id @default(cuid())
  variantId  String
  variant    ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  locationId String
  location   Location       @relation(fields: [locationId], references: [id])

  quantity   Int            @default(0)
  reserved   Int            @default(0) // held by in-progress orders
  version    Int            @default(0) // increment on every write; checked before update

  syncStatus SyncStatus     @default(SYNCED)
  lastSyncAt DateTime?      // timestamp of last successful POS sync
  posItemCode String?        // POS system item code for this SKU

  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@unique([variantId, locationId])
  @@index([locationId])
  @@index([syncStatus])
}

// ─────────────────────────────────────────────
// ORDERS
// ─────────────────────────────────────────────

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  PAID
  PARTIALLY_PAID
  REFUNDED
}

enum ShippingStatus {
  NOT_CREATED
  CREATED
  SHIPPED
  IN_TRANSIT
  OUT_FOR_DELIVERY
  DELIVERED
  FAILED
}

enum InvoiceStatus {
  PENDING
  CREATED
}

// How the customer wants to receive their order.
//   DELIVERY — courier (Delhivery) ships to the customer's address
//   PICKUP   — customer collects from the Manjeri store; no shipping fee,
//              no Delhivery shipment created, address fields optional
enum FulfillmentType {
  DELIVERY
  PICKUP
}

model Order {
  id                   String          @id @default(cuid())
  orderNumber          String          @unique // VCW-250405-0001
  customerName         String?
  customerEmail        String?
  customerPhone        String?
  locationId           String?         // where stock was deducted from
  shippingAddress      String?
  shippingCity         String?
  shippingState        String?
  shippingPincode      String?
  status               OrderStatus     @default(PENDING)
  paymentStatus        PaymentStatus   @default(UNPAID)
  // Fulfillment — DELIVERY (courier) or PICKUP (collect from shop)
  fulfillmentType      FulfillmentType @default(DELIVERY)
  pickupReadyAt        DateTime?       // staff marked the order ready to be collected
  pickedUpAt           DateTime?       // staff confirmed customer collected it
  // Delhivery shipping fields (only used when fulfillmentType = DELIVERY)
  shippingStatus       ShippingStatus  @default(NOT_CREATED)
  awbNumber            String?
  trackingUrl          String?
  delhiveryShipmentId  String?
  // Acrotex invoice fields
  invoiceStatus        InvoiceStatus   @default(PENDING)
  invoiceNumber        String?
  invoicePdfUrl        String?
  items                OrderItem[]
  subtotal             Decimal         @db.Decimal(10, 2)
  discount             Decimal         @default(0) @db.Decimal(10, 2)
  shippingFee          Decimal         @default(0) @db.Decimal(10, 2)
  total                Decimal         @db.Decimal(10, 2)
  notes                String?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  @@index([status])
  @@index([orderNumber])
  @@index([createdAt])
  @@index([awbNumber])
  @@index([fulfillmentType])
}

model OrderItem {
  id        String         @id @default(cuid())
  orderId   String
  order     Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variantId String
  variant   ProductVariant @relation(fields: [variantId], references: [id])
  quantity  Int
  unitPrice Decimal        @db.Decimal(10, 2) // price snapshot at time of sale

  @@index([orderId])
  @@index([variantId])
}

// ─────────────────────────────────────────────
// WEBHOOK LOG
// Generic audit trail for external POS events.
// Not coupled to any specific POS system.
// ─────────────────────────────────────────────

model WebhookLog {
  id           String    @id @default(cuid())
  source       String    // "POS" | "MANUAL" | future system name
  payload      Json      // raw incoming payload
  status       String    // "PENDING" | "SUCCESS" | "FAILED"
  errorMessage String?
  processedAt  DateTime?
  createdAt    DateTime  @default(now())

  @@index([source])
  @@index([status])
  @@index([createdAt])
}

// ─────────────────────────────────────────────
// ADMIN USERS
// Staff who log in to the admin panel.
// ─────────────────────────────────────────────

enum AdminRole {
  ADMIN
  MANAGER
  STAFF   // shop staff — POS scanner only, mobile-first UI, no sidebar
}

model AdminUser {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  passwordHash String
  role         AdminRole @default(MANAGER)
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([email])
}

// ─────────────────────────────────────────────
// HERO BANNERS
// Uploadable hero carousel slides for the storefront.
// Each slide stores separate images for desktop, tablet, and mobile.
// ─────────────────────────────────────────────

model HeroBanner {
  id           String   @id @default(cuid())
  sortOrder    Int      @default(0)        // display order (0 = first slide)
  isActive     Boolean  @default(true)

  // Text content
  eyebrow      String?
  titleLine1   String?
  titleLine2   String?
  subtitle     String?
  accentColor  String   @default("#8B6B47")
  darkTheme    Boolean  @default(false)     // white text on dark bg when true

  // CTA buttons
  ctaLabel     String?
  ctaHref      String?
  ctaAltLabel  String?
  ctaAltHref   String?

  // Responsive images (Cloudinary URLs)
  imageDesktop String?  // ≥1024px
  imageTablet  String?  // 768–1023px
  imageMobile  String?  // <768px

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([isActive])
  @@index([sortOrder])
}

// ─────────────────────────────────────────────
// INVENTORY HISTORY
// Audit trail for every stock change.
// ─────────────────────────────────────────────

enum InventoryAction {
  MANUAL    // staff typed a new quantity
  ORDER     // deducted on order placement
  IMPORT    // CSV import
  RESTOCK   // delta increase by staff
  ADJUSTMENT // delta decrease by staff
}

enum ReturnStatus {
  PENDING
  UNDER_REVIEW
  APPROVED
  REJECTED
  RESOLVED
}

model ReturnRequest {
  id            String       @id @default(cuid())
  orderNumber   String
  customerName  String
  customerEmail String
  customerPhone String
  reason        String       // always "damaged" for now
  description   String       @db.Text
  status        ReturnStatus @default(PENDING)
  adminNote     String?      @db.Text
  resolvedBy    String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([orderNumber])
  @@index([status])
  @@index([createdAt])
}

model InventoryHistory {
  id          String           @id @default(cuid())
  variantId   String
  variant     ProductVariant   @relation(fields: [variantId], references: [id], onDelete: Cascade)
  locationId  String?
  oldQuantity Int
  newQuantity Int
  delta       Int              // newQuantity - oldQuantity
  action      InventoryAction
  note        String?
  performedBy String?          // admin email or "system"
  createdAt   DateTime         @default(now())

  @@index([variantId])
  @@index([action])
  @@index([createdAt])
}

// ─────────────────────────────────────────────
// CUSTOMER REVIEWS
// Public testimonials for the storefront homepage.
// One review per email (enforced by unique index).
// ─────────────────────────────────────────────

// ─────────────────────────────────────────────
// CUSTOMERS — storefront users authenticated via Google Sign-In.
// Separate from AdminUser (staff), identified by Google `sub`.
// ─────────────────────────────────────────────

model Customer {
  id          String    @id @default(cuid())
  googleId    String    @unique
  email       String    @unique
  name        String
  picture     String?
  createdAt   DateTime  @default(now())
  lastLoginAt DateTime?
  updatedAt   DateTime  @updatedAt

  @@index([email])
}

model CustomerReview {
  id           String   @id @default(cuid())
  customerName String
  email        String   @unique
  body         String   @db.Text
  isApproved   Boolean  @default(true)
  createdAt    DateTime @default(now())

  @@index([isApproved, createdAt])
}

// ─────────────────────────────────────────────
// COUPON CODES — admin-issued discount / gift codes.
// Two flavours via `type`: PERCENT (% off subtotal) or FIXED (₹ off).
// `usageLimit` caps total redemptions; `usageCount` is server-incremented
// inside an optimistic transaction so two parallel checkouts can't both
// exceed the limit. `perCustomerLimit` caps redemptions per email.
// ─────────────────────────────────────────────

enum CouponType {
  PERCENT
  FIXED
}

model Coupon {
  id               String        @id @default(cuid())
  code             String        @unique           // stored uppercase
  description      String?
  type             CouponType    @default(PERCENT)
  value            Decimal       @db.Decimal(10, 2) // % or ₹ depending on type
  minOrderAmount   Decimal       @default(0) @db.Decimal(10, 2)
  maxDiscount      Decimal?      @db.Decimal(10, 2) // cap for PERCENT type
  usageLimit       Int           @default(1)        // total redemptions allowed
  usageCount       Int           @default(0)
  perCustomerLimit Int           @default(1)        // 0 = unlimited per customer
  startsAt         DateTime?
  expiresAt        DateTime?
  isActive         Boolean       @default(true)
  redemptions      CouponRedemption[]
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([code])
  @@index([isActive])
}

model CouponRedemption {
  id            String   @id @default(cuid())
  couponId      String
  coupon        Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  customerEmail String?
  orderNumber   String?
  amount        Decimal  @db.Decimal(10, 2)
  createdAt     DateTime @default(now())

  @@index([couponId])
  @@index([customerEmail])
}
