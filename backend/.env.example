# ── Database (Neon / PostgreSQL) ──────────────────────────────────────────────
# Pooled connection URL used by Prisma at runtime
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require

# Direct (non-pooled) URL required by Prisma Migrate
DIRECT_URL=postgresql://USER:PASSWORD@HOST-direct/DATABASE?sslmode=require

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate a strong secret: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_IN_PRODUCTION

# ── Cloudinary (media uploads) ────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
# Development:
# FRONTEND_URL=http://localhost:3000
# Production (Railway):
FRONTEND_URL=https://vamiclubwear.in

# ── Razorpay (online payments) ────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# ── Email (Resend HTTP API) ───────────────────────────────────────────────────
# Sign up at https://resend.com → API Keys → create a key
# Then add & verify the sending domain (vamiclubwear.in) under Domains.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Must be an address on a verified Resend domain
RESEND_FROM=Vami Clubwear <orders@vamiclubwear.in>
# Admin notification inbox for new-order alerts
STORE_EMAIL=vamiclubwear@gmail.com

# ── Delhivery Shipping ────────────────────────────────────────────────────────
# Get API token from https://app.delhivery.com → Settings → API
# Sandbox: https://staging-express.delhivery.com
DELHIVERY_TOKEN=your-delhivery-api-token
DELHIVERY_BASE_URL=https://track.delhivery.com
DELHIVERY_PICKUP_NAME=Primary
STORE_PINCODE=676122
STORE_ADDRESS=Manjeri, Kerala
STORE_CITY=Manjeri
STORE_STATE=Kerala
STORE_PHONE=+91XXXXXXXXXX

# SCANPUSH webhook secret — must match the value sent in the
# X-Delhivery-Secret header configured in the SCANPUSH requirement form.
# Generate: openssl rand -hex 32
DELHIVERY_WEBHOOK_SECRET=CHANGE_ME_STRONG_RANDOM_VALUE
