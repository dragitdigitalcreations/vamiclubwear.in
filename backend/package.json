{
  "name": "vami-clubwear-backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "tsx watch src/index.ts",
    "build": "prisma generate && tsc",
    "start": "prisma migrate deploy && node dist/index.js",
    "db:generate": "dotenv -e .env.local -- prisma generate",
    "db:migrate": "dotenv -e .env.local -- prisma migrate dev",
    "db:migrate:prod": "dotenv -e .env.local -- prisma migrate deploy",
    "db:reset": "dotenv -e .env.local -- prisma migrate reset --force",
    "db:studio": "dotenv -e .env.local -- prisma studio",
    "seed:admin": "dotenv -e .env.local -- tsx scripts/seed-admin.ts",
    "seed:data": "dotenv -e .env.local -- tsx scripts/seed-data.ts",
    "seed": "npm run seed:admin && npm run seed:data"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@types/multer": "^2.1.0",
    "@types/nodemailer": "^8.0.0",
    "@upstash/redis": "^1.37.0",
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.9.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.4",
    "prisma": "^5.22.0",
    "razorpay": "^2.9.6",
    "resend": "^6.11.0",
    "typescript": "^5.4.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.14.2",
    "dotenv-cli": "^11.0.0",
    "tsx": "^4.15.6"
  }
}
