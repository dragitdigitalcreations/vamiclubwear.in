# ── Secrets — NEVER commit these ──────────────
.env
.env.local
.env.*.local
*.pem
github-sa-key.json
*-sa-key.json

# ── Claude Code local files ────────────────────
.claude/

# ── Dependencies ───────────────────────────────
node_modules/
.pnp
.pnp.js

# ── Next.js build output ───────────────────────
frontend/.next/
frontend/out/

# ── Backend build output ───────────────────────
backend/dist/

# ── Cloud Run deploy artifacts ─────────────────
# env.yaml has no secrets (those are in Secret Manager) — safe to commit for CI
# deploy.sh and create-secrets.sh may contain local values — keep ignored
backend/deploy/*
!backend/deploy/env.yaml

# ── Prisma ─────────────────────────────────────
backend/prisma/migrations/dev.db
*.db
*.db-journal

# ── Logs ───────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── OS / Editor ────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo

# ── Testing ────────────────────────────────────
coverage/
.nyc_output/
.env.local
